{
    "git.autofetch": true,
    "git.confirmSync": false,
    "git.enableSmartCommit": true,
    "editor.inlineSuggest.enabled": true,
    "settingsSync.ignoredExtensions": [
      "github.copilot"
    ],
    "phpserver.phpPath": "/opt/homebrew/bin/php",
    "code-runner.runInTerminal": true,
    "code-runner.saveAllFilesBeforeRun": true,
    "code-runner.saveFileBeforeRun": true,
    "cmake.configureOnOpen": true,
    "github.copilot.enable": {
      "*": true,
      "plaintext": false,
      "markdown": false,
      "scminput": false,
      "c": false
    },
    "files.autoSave": "afterDelay",
    "cmake.showOptionsMovedNotification": false,
    "python.defaultInterpreterPath": "/Users/isaiah/opt/anaconda3/envs/ELEC292/bin/python",
    "terminal.integrated.inheritEnv": false,
    "python.autoComplete.extraPaths": [],
    "mypy.dmypyExecutable": "/Users/isaiah/opt/anaconda3/envs/ELEC292/bin/mypy",
    "python.analysis.extraPaths": [],
    "editor.maxTokenizationLineLength": 100000,
    "jupyter.askForKernelRestart": false,
    "github.copilot.editor.enableAutoCompletions": true,
    "docker.dockerPath": "/usr/local/bin/docker",
    "makefile.configureOnOpen": true,
    "cursor.cpp.disabledLanguages": [
      "plaintext",
      "markdown",
      "scminput",
      "c"
    ],
    "editor.accessibilitySupport": "on",
    "redhat.telemetry.enabled": true,
    "[cpp]": {},
    "database-client.autoSync": true,
    "workbench.colorTheme": "GitHub Dark Colorblind (Beta)",
    "workbench.colorCustomizations": {
      "terminal.background": "#00000000"
    },
    "terminal.integrated.gpuAcceleration": "off",
    "window.systemColorTheme": "dark",
    "window.autoDetectColorScheme": false,
    "window.titleBarStyle": "custom",
    "editor.fontFamily": "MesloLGS Nerd Font Mono",
    "terminal.integrated.fontFamily": "MesloLGS Nerd Font Mono",
    "editor.fontSize": 13,
    "editor.fontLigatures": true,
  
    // ========== VIM CONFIGURATION ==========
    // Enable Vim mode
    "vim.useSystemClipboard": true,
    "vim.useCtrlKeys": true,
    "vim.hlsearch": true,
    "vim.incsearch": true,
    "vim.ignorecase": true,
    "vim.smartcase": true,
    "vim.easymotion": true,
    "vim.sneak": true,
    "vim.surround": true,
    "vim.camelCaseMotion.enable": true,
    "vim.replaceWithRegister": true,
    
    // Scroll settings
    "vim.scroll": 10,
    "vim.smartRelativeLine": true,
    
    // Leader key (space is popular)
    "vim.leader": "<space>",
    
    // Handle keys that VSCode should control
    "vim.handleKeys": {
      "<C-d>": true,
      "<C-s>": false,
      "<C-z>": false,
      "<C-c>": false,
      "<C-v>": false,
      "<C-a>": false,
      "<C-f>": false
    },
    
    // Normal mode keybindings
    "vim.normalModeKeyBindingsNonRecursive": [
      // Better window navigation
      { "before": ["<C-h>"], "commands": ["workbench.action.navigateLeft"] },
      { "before": ["<C-j>"], "commands": ["workbench.action.navigateDown"] },
      { "before": ["<C-k>"], "commands": ["workbench.action.navigateUp"] },
      { "before": ["<C-l>"], "commands": ["workbench.action.navigateRight"] },
      
      // Split navigation
      { "before": ["<leader>", "h"], "commands": ["workbench.action.focusLeftGroup"] },
      { "before": ["<leader>", "j"], "commands": ["workbench.action.focusBelowGroup"] },
      { "before": ["<leader>", "k"], "commands": ["workbench.action.focusAboveGroup"] },
      { "before": ["<leader>", "l"], "commands": ["workbench.action.focusRightGroup"] },
      
      // Split creation
      { "before": ["<leader>", "v"], "commands": ["workbench.action.splitEditor"] },
      { "before": ["<leader>", "s"], "commands": ["workbench.action.splitEditorDown"] },
      
      // File explorer
      { "before": ["<leader>", "e"], "commands": ["workbench.view.explorer"] },
      
      // File operations
      { "before": ["<leader>", "w"], "commands": [":w!"] },
      { "before": ["<leader>", "q"], "commands": [":q!"] },
      { "before": ["<leader>", "x"], "commands": [":x!"] },
      
      // Clear search highlight
      { "before": ["<leader>", "n", "h"], "commands": [":nohl"] },
      
      // Quick file finder
      { "before": ["<leader>", "f", "f"], "commands": ["workbench.action.quickOpen"] },
      { "before": ["<leader>", "f", "g"], "commands": ["workbench.action.findInFiles"] },
      
      // Code actions
      { "before": ["<leader>", "c", "a"], "commands": ["editor.action.quickFix"] },
      { "before": ["<leader>", "r", "n"], "commands": ["editor.action.rename"] },
      
      // Go to definition/references
      { "before": ["g", "d"], "commands": ["editor.action.revealDefinition"] },
      { "before": ["g", "r"], "commands": ["editor.action.goToReferences"] },
      { "before": ["g", "i"], "commands": ["editor.action.goToImplementation"] },
      
      // Better indenting
      { "before": [">"], "commands": ["editor.action.indentLines"] },
      { "before": ["<"], "commands": ["editor.action.outdentLines"] },
      
      // Move lines up/down
      { "before": ["K"], "commands": ["editor.action.moveLinesUpAction"] },
      { "before": ["J"], "commands": ["editor.action.moveLinesDownAction"] },
      
      // Tab navigation
      { "before": ["H"], "commands": ["workbench.action.previousEditor"] },
      { "before": ["L"], "commands": ["workbench.action.nextEditor"] },
      
      // Close tab
      { "before": ["<leader>", "c"], "commands": ["workbench.action.closeActiveEditor"] },
      
      // Format document
      { "before": ["<leader>", "f", "m"], "commands": ["editor.action.formatDocument"] },
      
      // Toggle sidebar
      { "before": ["<leader>", "b"], "commands": ["workbench.action.toggleSidebarVisibility"] },
      
      // Center cursor
      { "before": ["<C-d>"], "after": ["<C-d>", "z", "z"] },
      { "before": ["<C-u>"], "after": ["<C-u>", "z", "z"] },
      
      // Keep cursor centered during search
      { "before": ["n"], "after": ["n", "z", "z", "z", "v"] },
      { "before": ["N"], "after": ["N", "z", "z", "z", "v"] }
    ],
    
    // Visual mode keybindings
    "vim.visualModeKeyBindingsNonRecursive": [
      // Better indenting
      { "before": [">"], "commands": ["editor.action.indentLines"] },
      { "before": ["<"], "commands": ["editor.action.outdentLines"] },
      
      // Move selected lines
      { "before": ["J"], "commands": ["editor.action.moveLinesDownAction"] },
      { "before": ["K"], "commands": ["editor.action.moveLinesUpAction"] },
      
      // Keep selection after indenting
      { "before": [">"], "after": [">", "g", "v"] },
      { "before": ["<"], "after": ["<", "g", "v"] },
      
      // Paste without yanking
      { "before": ["p"], "after": ["p", "g", "v", "y"] }
    ],
    
    // Insert mode keybindings
    "vim.insertModeKeyBindings": [
      // Quick escape
      { "before": ["j", "k"], "after": ["<Esc>"] },
      { "before": ["k", "j"], "after": ["<Esc>"] }
    ],
    
    // Disable default Vim status bar (use VSCode's)
    "vim.statusBarColorControl": false,
    "vim.statusBarColors.normal": ["#8FBCBB", "#434C5E"],
    "vim.statusBarColors.insert": ["#BF616A", "#434C5E"],
    "vim.statusBarColors.visual": ["#B48EAD", "#434C5E"],
    "vim.statusBarColors.visualline": ["#B48EAD", "#434C5E"],
    "vim.statusBarColors.visualblock": ["#A3BE8C", "#434C5E"],
    "vim.statusBarColors.replace": [
      "#D08770",
      "#434C5E"
    ],
    "cursorpyright.analysis.extraPaths": [],
    "containers.containerCommand": "/usr/local/bin/docker"
  }
